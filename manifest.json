{
  "manifest_version": 3,
  "name": "Data Scraper",
  "version": "1.1",
  "description": "Multi-site data extraction tool. Scrape structured data from Upwork, TikTok, and more.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "activeTab",
    "debugger",
    "scripting",
    "storage",
    "unlimitedStorage"
  ],
  "host_permissions": [
    "https://www.upwork.com/*",
    "https://www.tiktok.com/*"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "sandbox.html",
        "sandbox.js",
        "sites/upwork/panel.html",
        "sites/upwork/panel.js",
        "sites/tiktok/panel.html",
        "sites/tiktok/panel.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    },
    {
      "resources": [
        "sites/upwork/injected/job-post-page.js",
        "sites/upwork/injected/proposals-network-monitor.js"
      ],
      "matches": [
        "https://www.upwork.com/*"
      ]
    }
  ],
  "sandbox": {
    "pages": [
      "sandbox.html"
    ]
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'unsafe-eval'; object-src 'self';",
    "sandbox": "sandbox allow-scripts; script-src 'self' 'unsafe-eval'; object-src 'self';"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  }
}
